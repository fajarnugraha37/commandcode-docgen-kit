{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docgen:manifest:1.1",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "navigation",
    "pages"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "generatedAt": {
      "type": "string"
    },
    "navigation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "pages"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "pages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "title",
          "type",
          "category",
          "purpose",
          "summary",
          "evidence",
          "models",
          "audience",
          "requiredSections",
          "diagramIntents",
          "coverageTags",
          "relatedPages",
          "mode"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "path": {
            "type": "string",
            "pattern": "^docs/.*\\.md$"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "enum": [
              "overview",
              "architecture",
              "business",
              "concept",
              "flow",
              "guide",
              "reference",
              "data",
              "integration",
              "operations",
              "troubleshooting",
              "security",
              "testing",
              "configuration",
              "decision",
              "ownership",
              "maintenance",
              "tutorial",
              "runbook",
              "migration"
            ]
          },
          "category": {
            "type": "string"
          },
          "section": {
            "type": "string"
          },
          "order": {
            "type": "number"
          },
          "purpose": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "evidence": {
            "type": "array"
          },
          "models": {
            "type": "array"
          },
          "audience": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "requiredSections": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "diagramIntents": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "coverageTags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "requiredTables": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "relatedPages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "qualityHints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "mode": {
            "enum": [
              "tutorial",
              "how-to",
              "explanation",
              "reference",
              "runbook",
              "decision-record",
              "migration-guide",
              "troubleshooting"
            ]
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^docs/.*\\.md$"
            }
          },
          "status": {
            "enum": [
              "active",
              "deprecated",
              "draft",
              "experimental",
              "superseded"
            ]
          },
          "version": {
            "type": [
              "string",
              "null"
            ]
          },
          "deprecatedSince": {
            "type": [
              "string",
              "null"
            ]
          },
          "replacementPage": {
            "type": [
              "string",
              "null"
            ]
          },
          "migrationFrom": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "migrationTo": {
            "type": [
              "string",
              "null"
            ]
          },
          "exampleIntents": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "searchKeywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "frontmatter": {
            "type": "object"
          }
        }
      }
    }
  }
}
