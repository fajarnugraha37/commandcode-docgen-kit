{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docgen:evidence-artifact:1.0",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "kind",
    "scope",
    "facts"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "classification",
          "summary",
          "source"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "classification": {
            "enum": [
              "FACT",
              "INFERENCE",
              "UNKNOWN"
            ]
          },
          "summary": {
            "type": "string"
          },
          "source": {
            "type": "object",
            "required": [
              "path"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "symbol": {
                "type": "string"
              },
              "lines": {
                "type": "object"
              }
            }
          },
          "evidenceIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "details": {},
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}
