{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docgen:evidence-index:1.1",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "generatedAt": {
      "type": "string"
    },
    "repository": {
      "type": "object"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "kind",
          "scope"
        ]
      }
    }
  },
  "description": "Canonical evidence index. The orchestrator can normalize legacy/model-variant index shapes into artifacts[]."
}
