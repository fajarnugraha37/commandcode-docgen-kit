{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docgen:workflow:1.0",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "classification",
    "steps",
    "evidenceIds"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "classification": {
      "enum": [
        "FACT",
        "INFERENCE",
        "UNKNOWN"
      ]
    },
    "steps": {
      "type": "array"
    },
    "evidenceIds": {
      "type": "array"
    }
  }
}
